# Vite 環境変数のサンプル
# Vercel ダッシュボードで Production / Preview / Development それぞれに設定可能
# 未設定の場合 src/ 内のデフォルト値が使われる

# Supabase (デフォルト値が src/lib/supabase.ts にあるので任意)
# VITE_SUPABASE_URL=https://ercnehjywfphrgqaepzi.supabase.co
# VITE_SUPABASE_ANON_KEY=...

# 共愛会勤務表管理ポータル URL (戻るボタンの遷移先)
# admin-portal の Vercel デプロイ URL が変わった場合のみ設定
# VITE_PORTAL_URL=https://admin-portal-five-psi.vercel.app
